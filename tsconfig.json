{
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"types": [
			"node",
		],
		"allowImportingTsExtensions": true,
		"erasableSyntaxOnly": true,
		"strict": true,
		"noEmit": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
	},
	"include": [
		"scripts/**/*.ts",
	],
}
